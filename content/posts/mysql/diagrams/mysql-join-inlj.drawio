<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;INLJ: Index Nested-Loop Join — B+树查找代替全表扫描&lt;/b&gt;" style="text;html=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="40" y="8" width="540" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="user_row" value="&lt;b&gt;驱动表 users&lt;/b&gt;&lt;br&gt;user{id=5}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="30" y="60" width="110" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="bplus_root" value="&lt;b&gt;orders.user_id&lt;/b&gt;&lt;br&gt;B+树索引" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="200" y="55" width="120" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="leaf_hit" value="&lt;b&gt;叶子节点&lt;/b&gt;&lt;br&gt;user_id=5 → pk=42" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="370" y="55" width="130" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="pk_index" value="&lt;b&gt;主键索引&lt;/b&gt;&lt;br&gt;id=42 B+树查找" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontColor=#0D47A1;" vertex="1" parent="1">
      <mxGeometry x="370" y="130" width="130" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="full_row" value="&lt;b&gt;回表拿到完整行&lt;/b&gt;&lt;br&gt;order{id=42,&lt;br&gt;user_id=5,$99}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontColor=#0D47A1;" vertex="1" parent="1">
      <mxGeometry x="370" y="210" width="130" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e1" edge="1" parent="1" source="user_row" target="bplus_root" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1976D2;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="bplus_root" target="leaf_hit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#388E3C;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="leaf_hit" target="pk_index" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;dashed=1;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="pk_index" target="full_row" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="cost" value="&lt;b&gt;代价：每行 user → 3~4 次 IO (B+树查找)&lt;/b&gt;&lt;br&gt;1000 行 × 4 IO = 4000 IO (vs SNLJ 的 1 亿行扫描)" style="text;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="290" width="460" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="cover_note" value="&lt;b&gt;💡 更快&lt;/b&gt;：覆盖索引 = 省掉回表。INDEX(user_id, col1, col2) 让二级索引叶子直接包含SELECT列" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="50" y="340" width="490" height="30" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>