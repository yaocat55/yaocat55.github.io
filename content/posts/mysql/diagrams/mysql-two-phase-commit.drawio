<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;两阶段提交：Redo Log 与 Binlog 的一致性保证&lt;/b&gt;" style="text;html=1;fontSize:14;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="60" y="8" width="460" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="tx_begin" value="&lt;b&gt;BEGIN&lt;/b&gt; — 事务开始" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;fontColor=#212121;" vertex="1" parent="1">
      <mxGeometry x="200" y="50" width="175" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="dml" value="执行 UPDATE / INSERT / DELETE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="175" y="100" width="220" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="prepare" value="&lt;b&gt;❶ PREPARE 阶段&lt;/b&gt;&lt;br&gt;写 Redo Log (状态=PREPARE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#E64A19;fontSize=11;fontColor=#BF360C;" vertex="1" parent="1">
      <mxGeometry x="150" y="155" width="270" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="binlog" value="&lt;b&gt;❷ 写 Binlog&lt;/b&gt;&lt;br&gt;写入该事务的所有逻辑操作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
      <mxGeometry x="150" y="220" width="270" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="commit" value="&lt;b&gt;❸ COMMIT 阶段&lt;/b&gt;&lt;br&gt;Redo Log 状态=PREPARE → COMMIT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="135" y="285" width="300" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="done" value="&lt;b&gt;事务提交成功 ✅&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="190" y="350" width="190" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="crash_note" value="&lt;b&gt;⚡ 崩溃恢复时的判断&lt;/b&gt;&lt;br&gt;PREPARE + Binlog 完整 → COMMIT  |  PREPARE + Binlog 缺失 → ROLLBACK" style="text;html=1;fillColor=#E8EAF6;strokeColor=#1A237E;fontSize=10;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="400" width="440" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="e1" edge="1" parent="1" source="tx_begin" target="dml" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9E9E9E;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="dml" target="prepare" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1976D2;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="prepare" target="binlog" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E64A19;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="binlog" target="commit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="commit" target="done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#388E3C;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>