<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Hash Join (MySQL 8.0.18+) — 哈希表替代 B+树&lt;/b&gt;" style="text;html=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="80" y="8" width="480" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="phase1" value="&lt;b&gt;❶ Build 阶段&lt;/b&gt;&lt;br&gt;选小表建哈希表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="30" y="55" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="ht" value="&lt;b&gt;Hash Table (内存)&lt;/b&gt;&lt;br&gt;┌──────┬────────┐&lt;br&gt;│hash(5)│user{id=5}│&lt;br&gt;│hash(12)│user{id=12}│&lt;br&gt;│hash(20)│user{id=20}│&lt;br&gt;│  ... │  ...   │&lt;br&gt;└──────┴────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=9;fontColor=#1B5E20;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="110" width="200" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="phase2" value="&lt;b&gt;❷ Probe 阶段&lt;/b&gt;&lt;br&gt;逐行扫大表查哈希" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="300" y="55" width="170" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="probe_flow" value="&lt;b&gt;扫 orders 表&lt;/b&gt;&lt;br&gt;order{user_id=12}&lt;br&gt;→ hash(12)&lt;br&gt;→ 查哈希表&lt;br&gt;→ O(1) 命中！" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;" vertex="1" parent="1">
      <mxGeometry x="310" y="115" width="150" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="advantage" value="&lt;b&gt;🔑 优势&lt;/b&gt;&lt;br&gt;• 不需要被驱动表有索引&lt;br&gt;• O(M+N) 复杂度&lt;br&gt;• 内存不足时写磁盘临时文件" style="text;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;rounded=1;align=left;" vertex="1" parent="1">
      <mxGeometry x="50" y="240" width="380" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="limit" value="&lt;b&gt;⚠ 限制&lt;/b&gt;：仅等值连接有效（=、IN），范围条件 &gt; BETWEEN 回退 BNLJ" style="text;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="50" y="310" width="460" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="e_build" edge="1" parent="1" source="phase1" target="ht" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1976D2;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e_probe" edge="1" parent="1" source="phase2" target="probe_flow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1976D2;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e_probe_ht" edge="1" parent="1" source="probe_flow" target="ht" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;dashed=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>