    <mxCell id="advantage" value="&lt;b&gt;🔑 B+树 vs B树的核心优势：&lt;/b&gt;叶子链表让范围查询不需要回溯内部节点" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
