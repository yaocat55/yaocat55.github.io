<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;范围查询 WHERE age BETWEEN 20 AND 30 — 两步走&lt;/b&gt;" style="text;html=1;fontSize=16;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="130" y="8" width="500" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="step1" value="&lt;b&gt;❶ 树搜索：&lt;/b&gt;二分查找定位 age=20 的第一条记录 → 3~4 次 IO" style="text;html=1;fontSize=12;fillColor=#E8EAF6;strokeColor=none;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="50" width="440" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="step2" value="&lt;b&gt;❷ 链表扫描：&lt;/b&gt;沿 next 指针向右扫，直到 age &gt; 30 → 不需要回到内部节点" style="text;html=1;fontSize=12;fillColor=#E8EAF6;strokeColor=none;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="85" width="520" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="intL" value="age idx: 10~25" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="40" y="145" width="140" height="35" as="geometry"/>
