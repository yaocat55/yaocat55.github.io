      <mxGeometry x="380" y="145" width="140" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="leafA" value="...18&lt;br&gt;...19" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=10;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="40" y="230" width="80" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="leafB" value="20✓&lt;br&gt;22✓&lt;br&gt;25✓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="135" y="230" width="80" height="45" as="geometry"/>
    </mxCell>
