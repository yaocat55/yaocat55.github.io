    <mxCell id="eA" edge="1" parent="1" source="leafA" target="leafB" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;dashed=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="eB" edge="1" parent="1" source="leafB" target="leafC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;dashed=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="eC" edge="1" parent="1" source="leafC" target="leafD" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=2;dashed=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e_ilA" edge="1" parent="1" source="intL" target="leafA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1976D2;strokeWidth=1;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
