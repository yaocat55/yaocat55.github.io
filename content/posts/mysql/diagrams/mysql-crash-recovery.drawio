<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;崩溃恢复流程：Redo 重放 + Undo 回滚&lt;/b&gt;" style="text;html=1;fontSize:14;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="70" y="8" width="420" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="crash" value="&lt;b&gt;💥 突然断电&lt;/b&gt;&lt;br&gt;内存数据全部丢失" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;" vertex="1" parent="1">
      <mxGeometry x="180" y="50" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="redo" value="&lt;b&gt;第一步：Redo Log 重放&lt;/b&gt;&lt;br&gt;从 Checkpoint 之后开始&lt;br&gt;逐条按页号重放物理修改&lt;br&gt;→ 所有已记录修改都恢复了" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="140" y="115" width="280" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="undo" value="&lt;b&gt;第二步：Undo Log 回滚&lt;/b&gt;&lt;br&gt;扫描所有未提交事务&lt;br&gt;用 Undo Log 逆向操作&lt;br&gt;→ 未提交的全部回滚" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;" vertex="1" parent="1">
      <mxGeometry x="140" y="210" width="280" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="result" value="&lt;b&gt;✅ 恢复完成&lt;/b&gt;&lt;br&gt;已提交的 = 不丢&lt;br&gt;未提交的 = 滚回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="160" y="310" width="230" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="key" value="&lt;b&gt;🔑 Redo = 已提交不丢失 | Undo = 未提交滚回去&lt;/b&gt;" style="text;html=1;fillColor=#E8EAF6;strokeColor=none;fontSize=11;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="380" width="380" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="e1" edge="1" parent="1" source="crash" target="redo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="redo" target="undo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#388E3C;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="undo" target="result" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>