<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;Redo Log 循环写 &amp; Checkpoint 机制&lt;/b&gt;" style="text;html=1;fontSize:14;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="80" y="8" width="400" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="cycle_track" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="40" y="55" width="500" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="file1" value="&lt;b&gt;Redo Log File 1&lt;/b&gt;&lt;br&gt;ib_logfile0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=10;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="40" y="90" width="220" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="file2" value="&lt;b&gt;Redo Log File 2&lt;/b&gt;&lt;br&gt;ib_logfile1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=10;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="300" y="90" width="220" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="write_pos" value="&lt;b&gt;write_pos&lt;/b&gt; (写)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#E64A19;fontSize=10;fontColor=#BF360C;" vertex="1" parent="1">
      <mxGeometry x="450" y="50" width="80" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="ckpt_pos" value="&lt;b&gt;checkpoint&lt;/b&gt; (刷)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="300" y="150" width="90" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="explain_text" value="&lt;b&gt;write_pos - checkpoint = 可覆盖区域&lt;/b&gt;&lt;br&gt;两者之间 = 待刷盘的脏页对应的日志&lt;br&gt;写满时 write_pos 追上 checkpoint → 等待刷盘" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="205" width="420" height="48" as="geometry"/>
    </mxCell>
    <mxCell id="e_wp" edge="1" parent="1" source="write_pos" target="file2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E64A19;strokeWidth=2;dashed=1;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="arrow_c" edge="1" parent="1" source="file1" target="file2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1976D2;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="arrow_loop" value="🔄 循环" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#1976D2;" vertex="1" parent="1">
      <mxGeometry x="250" y="55" width="60" height="18" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>