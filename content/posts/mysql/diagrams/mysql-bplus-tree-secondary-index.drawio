<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;二级索引 + 回表过程&lt;/b&gt;" style="text;html=1;fontSize=17;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="180" y="8" width="400" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="label_left" value="&lt;b&gt;name 二级索引 B+树&lt;/b&gt;（叶子只存主键 id）" style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#7B1FA2;" vertex="1" parent="1">
      <mxGeometry x="60" y="45" width="220" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="label_right" value="&lt;b&gt;主键（聚簇）索引 B+树&lt;/b&gt;（叶子存完整行）" style="text;html=1;fontSize=12;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="400" y="45" width="250" height="30" as="geometry"/>
