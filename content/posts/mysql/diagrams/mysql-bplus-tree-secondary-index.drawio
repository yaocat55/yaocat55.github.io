    </mxCell>
    <mxCell id="cost_note" value="&lt;b&gt;⚠ 回表代价&lt;/b&gt;：每条记录一次独立的 B+树查找（3~4 次磁盘 IO）&lt;br&gt;查询 1000 行 ≈ 3000~4000 次磁盘 IO" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
