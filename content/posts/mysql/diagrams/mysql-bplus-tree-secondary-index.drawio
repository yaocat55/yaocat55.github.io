      <mxGeometry x="480" y="80" width="100" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="pk_leaf1" value="id=3: David,30,&lt;br&gt;david@xx.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=9;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="420" y="170" width="130" height="50" as="geometry"/>
    </mxCell>
