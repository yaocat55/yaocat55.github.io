      <mxGeometry x="100" y="80" width="100" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="s_leaf1" value="Alice → id=5&lt;br&gt;Bob → id=12&lt;br&gt;Charlie → id=8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontSize=10;fontColor=#6A1B9A;" vertex="1" parent="1">
      <mxGeometry x="30" y="170" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="s_leaf2" value="David → id=3&lt;br&gt;Eve → id=20&lt;br&gt;Frank → id=15" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#AB47BC;fontSize=10;fontColor=#6A1B9A;" vertex="1" parent="1">
      <mxGeometry x="165" y="170" width="120" height="50" as="geometry"/>
    </mxCell>
