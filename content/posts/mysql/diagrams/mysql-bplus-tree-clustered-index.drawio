      <mxGeometry x="30" y="55" width="230" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="root" value="&lt;b&gt;根&lt;/b&gt; id:(50)(100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=12;fontColor=#0D47A1;" vertex="1" parent="1">
