<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;BNLJ: Block Nested-Loop Join — Join Buffer 批量匹配&lt;/b&gt;" style="text;html=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="60" y="8" width="500" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="step1" value="&lt;b&gt;第 1 批&lt;/b&gt;：读 100 行 users 进 Buffer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="30" y="60" width="280" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="buffer1" value="&lt;b&gt;Join Buffer (256KB)&lt;/b&gt;&lt;br&gt;[user1][user2]...[user100]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="30" y="110" width="280" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="arrow1" value="&lt;b&gt;扫一次 orders 全表匹配&lt;/b&gt;" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="170" width="220" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="step2" value="&lt;b&gt;第 2 批&lt;/b&gt;：读下 100 行 users" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=11;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="30" y="220" width="280" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="buffer2" value="&lt;b&gt;Join Buffer&lt;/b&gt;&lt;br&gt;[user101]...[user200]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="30" y="270" width="280" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="result_box" value="&lt;b&gt;对比 SNLJ&lt;/b&gt;&lt;br&gt;扫描次数：1000 → 10 次&lt;br&gt;每次仍扫 10 万行&lt;br&gt;总扫描行数：&lt;b&gt;1000 万行&lt;/b&gt;&lt;br&gt;比 SNLJ 少 10 倍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontColor=#E65100;" vertex="1" parent="1">
      <mxGeometry x="340" y="100" width="240" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="tip" value="&lt;b&gt;💡 调优&lt;/b&gt;：增大 join_buffer_size → 批次更少 → 扫描次数更低&lt;br&gt;少选列 → 每行更小 → Buffer 能装更多行" style="text;html=1;fillColor=#E8EAF6;strokeColor=none;fontSize=10;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="340" width="460" height="35" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>