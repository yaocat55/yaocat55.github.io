<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;SNLJ: Simple Nested-Loop Join — 被驱动表全表扫描&lt;/b&gt;" style="text;html=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="60" y="8" width="500" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="driver_label" value="&lt;b&gt;驱动表 users (1000行)&lt;/b&gt;" style="text;html=1;fontSize=12;fillColor=#E3F2FD;strokeColor=#1976D2;fontColor=#1565C0;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="55" width="190" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="user1" value="user{id=1}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=10;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="40" y="95" width="85" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="user2" value="user{id=2}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=10;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="135" y="95" width="85" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="user_dots" value="..." style="text;html=1;fontSize=16;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="225" y="95" width="25" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="userN" value="user{id=1000}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=10;fontColor=#1565C0;" vertex="1" parent="1">
      <mxGeometry x="255" y="95" width="100" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="driven_label" value="&lt;b&gt;被驱动表 orders (10万行) — 无索引&lt;/b&gt;" style="text;html=1;fontSize=12;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="155" width="300" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="scan_box" value="&lt;b&gt;每行 user → 扫一遍 orders 全表&lt;/b&gt;&lt;br&gt;1000 次全表扫描&lt;br&gt;每次扫描 10 万行&lt;br&gt;总共扫描 &lt;b&gt;1 亿行&lt;/b&gt;！" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;" vertex="1" parent="1">
      <mxGeometry x="100" y="200" width="220" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="reject" value="&lt;b&gt;❌ O(M×N) 复杂度&lt;/b&gt;&lt;br&gt;任何实际场景不可接受" style="text;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="300" width="260" height="38" as="geometry"/>
    </mxCell>
    <mxCell id="e1" edge="1" parent="1" source="user1" target="scan_box" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="user2" target="scan_box" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="eN" edge="1" parent="1" source="userN" target="scan_box" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>