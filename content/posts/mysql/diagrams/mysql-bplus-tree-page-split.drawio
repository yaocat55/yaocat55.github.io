<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;页分裂 (Page Split) — 三阶段过程&lt;/b&gt;" style="text;html=1;fontSize=16;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="130" y="8" width="420" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="stage1_label" value="&lt;b&gt;阶段 ❶：满页（16KB 已满，Free Space 不足）&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=#E8EAF6;strokeColor=none;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="50" width="380" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="old_page" value="&lt;b&gt;已满页 (Page A)&lt;/b&gt;&lt;br&gt;┌─ User Records ─┐&lt;br&gt;│ ██████████████ │&lt;br&gt;│ ██ 100%占用 ██ │&lt;br&gt;│ ██████████████ │&lt;br&gt;└─ Free Space:0B ┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=9;fontColor=#B71C1C;align=left;" vertex="1" parent="1">
      <mxGeometry x="40" y="85" width="140" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="insert_label" value="&lt;b&gt;写入新记录&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=#FFCCBC;strokeColor=#E64A19;fontColor=#BF360C;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="210" y="115" width="100" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="arrow_s1" value="" edge="1" parent="1" source="old_page" target="new_page_a" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E64A19;strokeWidth=2;endArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="stage2_label" value="&lt;b&gt;阶段 ❷：分配新页 + 数据对半分&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=#E8EAF6;strokeColor=none;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="205" width="380" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="new_page_a" value="&lt;b&gt;Page A (前一半)&lt;/b&gt;&lt;br&gt;┌─ User Records ─┐&lt;br&gt;│ █████ ~50%    │&lt;br&gt;│              │&lt;br&gt;│ Free:~8KB    │&lt;br&gt;└──────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=9;fontColor=#1B5E20;align=left;" vertex="1" parent="1">
      <mxGeometry x="40" y="240" width="140" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="new_page_b" value="&lt;b&gt;Page B (后一半) ✨新&lt;/b&gt;&lt;br&gt;┌─ User Records ─┐&lt;br&gt;│ █████ ~50%    │&lt;br&gt;│              │&lt;br&gt;│ Free:~8KB    │&lt;br&gt;└──────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=9;fontColor=#1B5E20;align=left;" vertex="1" parent="1">
      <mxGeometry x="240" y="240" width="140" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="linked" value="&lt;b&gt;A.next ↔ B.prev&lt;/b&gt;" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
      <mxGeometry x="185" y="275" width="50" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="stage3_label" value="&lt;b&gt;阶段 ❸：父节点新增键 + 指针 → 递归检查&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=#E8EAF6;strokeColor=none;fontColor=#1A237E;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="360" width="380" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="parent" value="&lt;b&gt;父节点&lt;/b&gt;&lt;br&gt;旧: [ ... | 指针A ]&lt;br&gt;新: [ ... | 指针A | &lt;b&gt;新键B | 指针B&lt;/b&gt; ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=9;fontColor=#0D47A1;align=left;" vertex="1" parent="1">
      <mxGeometry x="100" y="400" width="220" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="recurse_note" value="&lt;b&gt;⚠ 父节点满了？→ 继续向上分裂，直到根。根满了 → 新根 + 树高+1&lt;/b&gt;" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="475" width="460" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="e_AB" edge="1" parent="1" source="new_page_a" target="new_page_b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=1.5;dashed=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
  </root>
</mxGraphModel>