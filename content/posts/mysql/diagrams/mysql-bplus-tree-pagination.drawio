<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;分页查询：LIMIT 1000000, 10 为什么慢&lt;/b&gt;" style="text;html=1;fontSize=16;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="100" y="8" width="480" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="bad_title" value="&lt;b&gt;❌ LIMIT 1000000, 10 — 跳过 100 万行只是不返回，不是不读&lt;/b&gt;" style="text;html=1;fontSize=12;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="50" width="500" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="leaf1" value="第0页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=9;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="30" y="110" width="70" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="leaf2" value="第1页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=9;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="110" y="110" width="70" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="dots1" value="..." style="text;html=1;fontSize=18;fillColor=none;strokeColor=none;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="180" y="112" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="leafN" value="第N页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=9;fontColor=#B71C1C;" vertex="1" parent="1">
      <mxGeometry x="220" y="110" width="70" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="dots2" value="..." style="text;html=1;fontSize=18;fillColor=none;strokeColor=none;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="290" y="112" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="target" value="目标页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="370" y="110" width="70" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="dots3" value="..." style="text;html=1;fontSize=18;fillColor=none;strokeColor=none;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="440" y="112" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="skip_label" value="&lt;b&gt;─── 必须逐条扫过（但不返回）───&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=none;strokeColor=none;fontColor=#C62828;" vertex="1" parent="1">
      <mxGeometry x="100" y="85" width="300" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="return_label" value="&lt;b&gt;返回&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=none;strokeColor=none;fontColor=#388E3C;" vertex="1" parent="1">
      <mxGeometry x="385" y="85" width="50" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="e1" edge="1" parent="1" source="leaf1" target="leaf2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9E9E9E;strokeWidth=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="leaf2" target="target" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=2;dashed=1;endArrow=classic;startArrow=classic;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="solution" value="&lt;b&gt;✅ 解决方案：游标分页&lt;/b&gt;&lt;br&gt;第一页：SELECT * ORDER BY id LIMIT 10&lt;br&gt;第二页：SELECT * WHERE id &gt; 10 ORDER BY id LIMIT 10 (用上一页最后 id 做起点)" style="text;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;rounded=1;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="180" width="530" height="48" as="geometry"/>
    </mxCell>
    <mxCell id="note" value="&lt;b&gt;⚠ 局限性：&lt;/b&gt;跳页、多列排序、复杂 WHERE 条件时游标分页不适用" style="text;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;fontColor=#E65100;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="240" width="420" height="28" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>