<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="&lt;b&gt;RC vs RR：ReadView 创建时机决定隔离行为&lt;/b&gt;" style="text;html=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#1a237e;" vertex="1" parent="1">
      <mxGeometry x="60" y="8" width="450" height="32" as="geometry"/>
    </mxCell>
    <mxCell id="rc_box" value="&lt;b&gt;READ COMMITTED (RC)&lt;/b&gt;" style="swimlane;startSize=28;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontColor=#0D47A1;" vertex="1" parent="1">
      <mxGeometry x="30" y="55" width="280" height="240" as="geometry"/>
    </mxCell>
    <mxCell id="rc_step1" value="SELECT 1 → 创建 ReadView_A" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=9;fontColor=#1565C0;" vertex="1" parent="rc_box">
      <mxGeometry x="15" y="40" width="250" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="rc_other" value="（事务B提交了修改）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;fontColor=#E65100;" vertex="1" parent="rc_box">
      <mxGeometry x="60" y="78" width="160" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="rc_step2" value="SELECT 2 → 创建 ReadView_B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontSize=9;fontColor=#1565C0;" vertex="1" parent="rc_box">
      <mxGeometry x="15" y="110" width="250" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="rc_result" value="&lt;b&gt;结果：两次读可能不同&lt;/b&gt;&lt;br&gt;每次都是最新快照" style="text;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;rounded=1;" vertex="1" parent="rc_box">
      <mxGeometry x="40" y="170" width="200" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="rr_box" value="&lt;b&gt;REPEATABLE READ (RR)&lt;/b&gt;" style="swimlane;startSize=28;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="340" y="55" width="280" height="240" as="geometry"/>
    </mxCell>
    <mxCell id="rr_step1" value="SELECT 1 → 创建 ReadView_Only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#43A047;fontSize=9;fontColor=#1B5E20;" vertex="1" parent="rr_box">
      <mxGeometry x="15" y="40" width="250" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="rr_other" value="（事务B提交了修改）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;fontColor=#E65100;" vertex="1" parent="rr_box">
      <mxGeometry x="60" y="78" width="160" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="rr_step2" value="SELECT 2 → 🔒 复用 ReadView_Only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#43A047;fontSize=9;fontColor=#1B5E20;" vertex="1" parent="rr_box">
      <mxGeometry x="15" y="110" width="250" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="rr_result" value="&lt;b&gt;结果：两次读一定相同&lt;/b&gt;&lt;br&gt;用同一个快照" style="text;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontColor=#1B5E20;rounded=1;" vertex="1" parent="rr_box">
      <mxGeometry x="40" y="170" width="200" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="warning" value="&lt;b&gt;⚠ RR 代价&lt;/b&gt;：长事务 ReadView 过期 → 阻止 Purge 清理 Undo Log → Undo 膨胀" style="text;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="320" width="540" height="32" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>